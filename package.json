{
  "name": "global-passport-api",
  "version": "1.0.50",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "bun run --watch src/app.ts",
    "start": "NODE_ENV=production bun src/app.ts",
    "lint": "ultracite fix",
    "auth:generate": "bunx --bun @better-auth/cli generate --output ./src/database/schema/auth.ts",
    "db:generate": "bunx --bun drizzle-kit generate",
    "db:migrate": "bunx --bun drizzle-kit migrate",
    "db:seed": "bun src/database/seed.ts",
    "db:studio": "bunx --bun drizzle-kit studio"
  },
  "dependencies": {
    "@react-email/components": "^0.5.7",
    "better-auth": "^1.5.5",
    "drizzle-orm": "^1.0.0-beta.17-67b1795",
    "hono": "^4.7.4",
    "pg": "^8.20.0",
    "resend": "^6.9.3",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@faker-js/faker": "^10.3.0",
    "@types/pg": "^8.18.0",
    "bun-types": "latest",
    "drizzle-kit": "^1.0.0-beta.17-67b1795",
    "ultracite": "5.4.3",
    "wrangler": "^4.79.0"
  },
  "module": "src/index.js"
}
